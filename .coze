[project]
requires = ["nodejs-24"]

[dev]
build = ["cd api && pnpm install"]
run = ["node", "api/server.js", "--static", "/workspace/projects"]
cwd = "/workspace/projects"

[deploy]
build = ["cd api && pnpm install"]
run = ["node", "api/server.js", "--static", "/workspace/projects"]
cwd = "/workspace/projects"
